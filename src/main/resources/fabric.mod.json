{
    "schemaVersion": 1,
    "id": "optimisedcushions",
    "version": "${version}",
    "name": "Optimised Cushions",
    "description": "Optimises cushion entities on both sides: bakes static cushions into chunk meshes on the client and strips their per-tick entity/tracker overhead on the server. Fully vanilla-compatible, works with vanilla clients.",
    "authors": [
        "NikitaCartes"
    ],
    "contact": {},
    "license": "MIT",
    "icon": "assets/optimisedcushions/icon.png",
    "environment": "*",
    "accessWidener": "optimisedcushions.accesswidener",
    "entrypoints": {
        "client": [
            "xyz.nikitacartes.optimisedcushions.OptimisedCushionsClient"
        ]
    },
    "mixins": [
        {
            "config": "optimisedcushions.client.mixins.json",
            "environment": "client"
        },
        "optimisedcushions.mixins.json"
    ],
    "depends": {
        "fabricloader": ">=0.19.3",
        "minecraft": "~26.3-",
        "java": ">=25",
        "fabric-api": "*"
    }
}
