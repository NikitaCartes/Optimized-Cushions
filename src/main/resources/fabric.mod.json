{
    "schemaVersion": 1,
    "id": "optimizedcushions",
    "version": "${version}",
    "name": "Optimized Cushions",
    "description": "Optimizes cushion entities on both sides: client- and server-side. Fully vanilla-compatible, works with vanilla clients and servers.",
    "authors": [
        "NikitaCartes"
    ],
    "contact": {
        "homepage": "https://github.com/NikitaCartes/Optimized-Cushions",
        "sources": "https://github.com/NikitaCartes/Optimized-Cushions",
        "issues": "https://github.com/NikitaCartes/Optimized-Cushions/issues",
        "discord": "https://discord.gg/UY4nhvUzaK"
    },
    "license": "MIT",
    "icon": "assets/optimizedcushions/icon.png",
    "environment": "*",
    "accessWidener": "optimizedcushions.accesswidener",
    "entrypoints": {
        "client": [
            "xyz.nikitacartes.optimizedcushions.OptimizedCushionsClient"
        ]
    },
    "mixins": [
        {
            "config": "optimizedcushions.client.mixins.json",
            "environment": "client"
        },
        "optimizedcushions.mixins.json"
    ],
    "depends": {
        "fabricloader": ">=0.19.3",
        "minecraft": "~26.3-",
        "java": ">=25",
        "fabric-api": "*"
    }
}
